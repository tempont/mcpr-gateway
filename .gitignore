# =============================================================================
# Local / experimental (not part of the published tree)
# =============================================================================
implementation/
.claude/
.codex/
.cursor/
.tmp/

# =============================================================================
# Dependencies & build
# =============================================================================
node_modules/
dist/
*.tsbuildinfo

# Package managers
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# =============================================================================
# Environment & secrets
# =============================================================================
.env
.env.*.local

# =============================================================================
# Application config (copy from *.example / templates)
# =============================================================================
config/gateway.json
config/bootstrap.json

# =============================================================================
# Tests & quality
# =============================================================================
coverage/
.vitest/

# Fixture dirs created by Vitest suites (beforeAll / tmp dirs — see __tmp_* in tests)
test/**/__tmp_*__/

# =============================================================================
# Data & SQLite (local persistence + WAL sidecars)
# =============================================================================
data/
*.db-shm
*.db-wal

# =============================================================================
# Benchmarks (generated data & reports only; keep bench/*.ts sources tracked)
# =============================================================================
bench/datasets/local/
bench/reports/

# =============================================================================
# Code intelligence / index (regenerate with `npx gitnexus analyze`)
# =============================================================================
.gitnexus/

# =============================================================================
# OS & editors (common noise)
# =============================================================================
.DS_Store
Thumbs.db
*.swp
*.swo
*~

.idea/
*.sublime-workspace

# Agent instruction files at repo root (often symlinked or copied per machine)
AGENTS.md
CLAUDE.md
.opencode
