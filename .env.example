# ─── Server ──────────────────────────────────────────────────────────────────
# Bind address. Use 0.0.0.0 for Docker/LAN; keep 127.0.0.1 for local-only.
# Note: with 127.0.0.1, MCP clients must use http://127.0.0.1 not http://localhost
# (localhost may resolve to ::1 and fail). Set GATEWAY_DUAL_STACK=1 to bind both.
# GATEWAY_DUAL_STACK=1
HOST=127.0.0.1

# UI port (Vite in dev, static in prod). With `npm run dev`, the gateway uses PORT+1.
# Docker Compose serves both UI and MCP on this same PORT inside the container.
PORT=3000

LOG_LEVEL=info

# Directory that holds bootstrap.json (optional). Docker images use /config.
# CONFIG_PATH=./config


# ─── Security — set these before `npm start` / Docker ────────────────────────
# The built/default runtime refuses to start while these values are empty or still
# using the example placeholders below. Replace every `change-me-*` value with
# your own secrets before publishing.

# Enables authentication on all /admin/* routes.
# Any non-empty string works — it is not the login password.
ADMIN_TOKEN=change-me-admin-token

# Admin panel login credentials (required when ADMIN_TOKEN is set).
GATEWAY_ADMIN_USER=change-me-admin-user
GATEWAY_ADMIN_PASSWORD=change-me-admin-password

# AES-256-GCM key for downstream bearer/OAuth credentials stored in SQLite.
# Must be a base64-encoded 32-byte value. Generate: openssl rand -base64 32.
# Strongly recommended to set this.
DOWNSTREAM_AUTH_ENCRYPTION_KEY=change-me-base64-32-byte-key


# ─── Demo mode ────────────────────────────────────────────────────────────────
# DEMO_MODE=true forces the gateway into a safe public-demo state:
# - All identities resolved as anonymous (no auth bypass possible)
# - In-memory sessions only (no disk persistence, SQLite disabled)
# - Admin routes are accessible with default credentials (user: demo, password: demo)
# - Debug routes and embedded OAuth routes return 404
# - WebUI shows a persistent "DEMO MODE" amber banner
# - Login page displays the demo credentials
# - env var is read once at startup; changing it requires a restart
# DEMO_MODE=false


# ─── Persistence ─────────────────────────────────────────────────────────────
# Default backend is SQLite. Set to "memory" to disable on-disk storage
# (sessions lost on restart; no audit table; no persisted downstream secrets).
# SESSION_BACKEND=memory

# SQLite file path (ignored when SESSION_BACKEND=memory).
# DATABASE_PATH=./data/gateway.db


# ─── Tuning ──────────────────────────────────────────────────────────────────
# Docker Compose uses this file and expects production-safe defaults.
# NODE_ENV=production

# Default retention window for `DELETE /admin/audit/prune` (days).
# AUDIT_RETENTION_DAYS=90

# Override the built UI directory (default: ui/dist, then ui/build).
# UI_STATIC_DIR=./ui/build


# ─── Custom variables for downstream MCP servers ─────────────────────────────
# Use these for env-var placeholders that you can set on WeBUI).
# YOUR_VARIABLE_NAME=your-value
